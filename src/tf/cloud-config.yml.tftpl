#cloud-config

package_update: true
package_upgrade: true
package_reboot_if_required: true

users:
  - name: ${user}
    ssh_authorized_keys: ${jsonencode(ssh_keys)}
    sudo: ['ALL=(ALL) NOPASSWD:ALL']
    shell: /bin/bash

ssh_pwauth: no

write_files:
  - path: /etc/sysctl.d/99-ipforward.conf
    permissions: '0644'
    content: |
      net.ipv4.ip_forward=1

runcmd:
  - sysctl --system
  - sudo ufw disable
  - sudo systemctl disable ufw
